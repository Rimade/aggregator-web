NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# UUID демо-кафе из `supabase/seed.sql` (нужно для реального создания заказов,
# пока каталог/меню остаётся моковым).
NEXT_PUBLIC_DEMO_CAFE_ID="11111111-1111-1111-1111-111111111111"

# Только для серверной части (Route Handlers). НИКОГДА не делай NEXT_PUBLIC.
# Нужен, чтобы панель платформы могла создавать пользователей/кафе через Admin API.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
